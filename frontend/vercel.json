{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://helplink-backend-production.up.railway.app/api/:path*"
    },
    {
      "source": "/ws",
      "destination": "https://helplink-backend-production.up.railway.app/ws"
    },
    {
      "source": "/((?!api|ws).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,PUT,DELETE,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ]
}